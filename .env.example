HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation
DATA_CACHE_PATH=data/cache/restaurants.parquet
MAX_CANDIDATES=20
MIN_CANDIDATES=3
TOP_N_RESULTS=5

# Groq LLM (production) — https://console.groq.com/
LLM_PROVIDER=groq
LLM_API_KEY=
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1500
LLM_TIMEOUT_SECONDS=30
LLM_LOG_PROMPTS=false

# API
CORS_ORIGINS=*

# Dev / CI only
# LLM_PROVIDER=mock
